# Copy to .env and set required values:
#   cp .env.example .env
#
# Required for LLM calls:
#   AZURE_OPENAI_API_KEY
#   AZURE_OPENAI_ENDPOINT

# --- Azure OpenAI (required) ---
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_RESPONSES_API_VERSION=2025-03-01-preview

# --- LLM deployments ---
LLM_MODEL=gpt-4o-mini
WRITER_LLM_MODEL=gpt-4o
WEB_SEARCH_MODEL=
LLM_TEMPERATURE=0.1
LLM_MAX_RETRIES=2
LLM_TIMEOUT_S=45.0
WRITER_LLM_TEMPERATURE=0.55
WEB_SEARCH_TIMEOUT_S=120.0

# --- External signals (target enrichment only) ---
EXTERNAL_SIGNAL_PROVIDER=disabled
EXTERNAL_SIGNAL_MAX_RESULTS=6

# --- Embeddings / NLI ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
NLI_MODEL=cross-encoder/nli-deberta-v3-xsmall
NLI_ENTAILMENT_THRESHOLD=0.55

# --- Crawling ---
CRAWL_MAX_PAGES=12
CRAWL_MAX_DEPTH=2
CRAWL_PAGE_TIMEOUT_S=20.0
CRAWL_CONCURRENCY=6
CRAWL_HEADLESS=true
CRAWL_USER_AGENT=ArtisanEvidenceBot/1.0 (+https://artisan.example/evidence-bot)
CRAWL_JS_FALLBACK_MIN_CHARS=400

# --- Sectioning ---
MAX_SECTION_CHARS=1800
SECTION_OVERLAP_CHARS=120

# --- Extraction ---
EXTRACT_CONCURRENCY=10
EXTRACT_BATCH_SIZE=10

# --- Target crawl limits ---
TARGET_CRAWL_MAX_PAGES=5
TARGET_CRAWL_MAX_DEPTH=1
TARGET_MAX_CRAWL_PASSES=1
TARGET_MAX_SECTIONS_FOR_EXTRACTION=40
FETCH_MORE_MAX_PAGES=2

# --- Storage (Docker Compose overrides paths to /data) ---
DATA_DIR=data
DB_PATH=data/artisan.db
CRAWL_CACHE_DIR=data/crawl

# --- Observability ---
MLFLOW_TRACKING_URI=file:./data/mlruns
MLFLOW_EXPERIMENT=artisan-outbound

# --- API ---
CORS_ORIGINS=http://localhost:3000

# --- Frontend (local dev without Docker proxy; set in shell or frontend/.env.local) ---
# BACKEND_URL=http://localhost:8000
